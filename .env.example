# API Configuration
# CoinGecko API base URL
NEXT_PUBLIC_COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Optional: CoinGecko API Key (leave empty for free tier)
# Get your API key from: https://www.coingecko.com/en/api/pricing
NEXT_PUBLIC_COINGECKO_API_KEY=

# Currency Settings
NEXT_PUBLIC_DEFAULT_CURRENCY=usd

# Refresh Intervals (in milliseconds)
# Market overview refresh interval (default: 60000 = 1 minute)
NEXT_PUBLIC_MARKET_REFRESH_INTERVAL=60000

# Hero section refresh interval (default: 30000 = 30 seconds)
NEXT_PUBLIC_HERO_REFRESH_INTERVAL=30000

# Application Settings
NEXT_PUBLIC_APP_NAME=CryptoVault

# Default number of cryptocurrencies to fetch
NEXT_PUBLIC_DEFAULT_CRYPTO_LIMIT=10
